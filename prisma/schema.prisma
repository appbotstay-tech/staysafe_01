  criadoEm          DateTime                       @default(now())
  atualizadoEm      DateTime                       @updatedAt
  produtos          EtiquetaValidadeProdutoGrupo[]
  regras            EtiquetaValidadeRegra[]
  etiquetasGrupo    EtiquetaValidadeEmissao[]      @relation("EtiquetaValidadeEmissaoGrupo")
  etiquetasSubgrupo EtiquetaValidadeEmissao[]      @relation("EtiquetaValidadeEmissaoSubgrupo")

