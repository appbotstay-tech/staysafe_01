generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RegistroInicial {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum StatusFechamentoHortifruti {
  ABERTO
  ASSINADO
}

enum TipoOpcaoHigienizacao {
  HORTIFRUTI
  PRODUTO_UTILIZADO
}

enum TurnoTemperaturaEquipamento {
  MANHA
  TARDE
}

enum StatusTemperaturaEquipamento {
  CONFORME
  ALERTA
  CRITICO
}

enum StatusOperacionalEquipamento {
  EM_OPERACAO
  MANUTENCAO
  INATIVO
}

enum StatusFechamentoTemperaturaEquipamento {
  ABERTO
  ASSINADO
}

enum TipoOpcaoTemperaturaEquipamento {
  EQUIPAMENTO
  ACAO_CORRETIVA
}

enum CategoriaEquipamentoTemperatura {
  REFRIGERACAO
  CONGELAMENTO
  QUENTE
}

enum StatusQualidadeOleo {
  ADEQUADO
  ATENCAO
  ULTIMA_UTILIZACAO
  DESCARTAR
  SEM_UTILIZACAO
}

enum StatusFechamentoQualidadeOleo {
  ABERTO
  ASSINADO
}

enum ConformidadeRecebimento {
  CONFORME
  NAO_CONFORME
}

enum StatusRecebimento {
  PENDENTE
  CONFORME
  NAO_CONFORME
}

enum StatusFechamentoRastreabilidadeRecebimento {
  ABERTO
  ASSINADO
}

enum TipoTemperaturaRecebimento {
  NUMERICA
  AMBIENTE
  NAO_APLICAVEL
}

enum StatusNotaRecebimento {
  PENDENTE
  IMPORTADA
  EM_CONFERENCIA
  FINALIZADA
}

enum TurnoPlanoLimpeza {
  MANHA
  TARDE
  NOITE
}

enum StatusPlanoLimpeza {
  PENDENTE
  AGUARDANDO_SUPERVISOR
  CONCLUIDO
}

enum TipoPlanoLimpeza {
  DIARIO
  SEMANAL
}

enum StatusFechamentoPlanoLimpeza {
  ABERTO
  ASSINADO
}

enum ClassificacaoItemBuffetAmostra {
  QUENTE
  FRIO
  TEMPERATURA_AMBIENTE
}

enum StatusItemBuffetAmostra {
  PENDENTE
  PREENCHIDO
  ASSINADO
  NAO_SERVIDO
}

enum StatusTemperaturaBuffetAmostra {
  CONFORME
  ALERTA
  CRITICO
}

enum StatusFechamentoBuffetAmostra {
  ABERTO
  ASSINADO
}

enum TipoServicoBuffetAmostra {
  FIXO
  ESPORADICO
}

enum PerfilUsuario {
  DEV
  GERENTE
  NUTRICIONISTA
  COLABORADOR
}

enum StatusUsuario {
  ATIVO
  INATIVO
}

enum StatusSolicitacaoRedefinicaoSenha {
  PENDENTE
  ATENDIDA
  CANCELADA
}

enum TipoAssinaturaSistema {
  RESPONSAVEL
  SUPERVISOR
  RESPONSAVEL_TECNICO
  FECHAMENTO_MENSAL
  REVISAO_NUTRICIONISTA
}

enum OrigemChamadoManutencao {
  TEMPERATURA
  LIMPEZA
  OLEO
  RECEBIMENTO
  HORTIFRUTI
  BUFFET_AMOSTRAS
  MANUAL
}

enum PrioridadeChamadoManutencao {
  BAIXA
  MEDIA
  ALTA
}

enum StatusChamadoManutencao {
  ABERTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum DocumentoTipo {
  LEGISLACAO
  LAUDO
  POP_MANUAL
}

enum ModuloDocumento {
  DASHBOARD_RESUMO_BPMA
  HIGIENIZACAO_HORTIFRUTI
  CONTROLE_TEMPERATURA
  CONTROLE_QUALIDADE_OLEO
  RASTREABILIDADE_RECEBIMENTO
  CONTROLE_BUFFET_AMOSTRAS
  PLANO_LIMPEZA_DIARIO
  PLANO_LIMPEZA_SEMANAL
  CHAMADOS_MANUTENCAO
  RELATORIOS_AUDITORIA
}

enum EtiquetaValidadeOrigem {
  CADASTRADO
  LIVRE
}

enum EtiquetaValidadeOrigemRegra {
  AUTOMATICA
  MANUAL
}

model Usuario {
  id                             Int                           @id @default(autoincrement())
  nomeCompleto                   String
  nomeUsuario                    String                        @unique
  senhaHash                      String
  perfil                         PerfilUsuario
  perfilAcessoId                 Int?
  perfilAcesso                   PerfilAcesso?                 @relation(fields: [perfilAcessoId], references: [id], onDelete: SetNull)
  isDevDefinitivo                Boolean                       @default(false)
  status                         StatusUsuario                 @default(ATIVO)
  dataAdmissao                   DateTime?                     @db.Date
  createdAt                      DateTime                      @default(now())
  updatedAt                      DateTime                      @updatedAt
  ultimaAlteracaoSenha           DateTime?
  obrigarTrocaSenha              Boolean                       @default(false)
  ultimoAcesso                   DateTime?
  observacoesInternas            String?
  sessoes                        UsuarioSessao[]
  solicitacoesComoAlvo           SolicitacaoRedefinicaoSenha[] @relation("SolicitacaoUsuarioAlvo")
  solicitacoesTratadas           SolicitacaoRedefinicaoSenha[] @relation("SolicitacaoTratadaPor")
  logsAssinatura                 LogAssinatura[]
  chamadosManutencaoCriados      ChamadoManutencao[]           @relation("ChamadoCriadoPor")
  documentosTecnicosCriados      DocumentoTecnicoAnexo[]       @relation("DocumentoTecnicoCriadoPor")
  configuracoesModuloAtualizadas ModuloConfiguracao[]          @relation("ModuloConfiguracaoAtualizadoPor")
  etiquetasValidadeGeradas       EtiquetaValidadeGerada[]      @relation("EtiquetaValidadeResponsavel")
  etiquetasValidadeEmissoes      EtiquetaValidadeEmissao[]     @relation("EtiquetaValidadeEmissaoResponsavel")

  @@index([perfilAcessoId])
  @@index([perfil, status, isDevDefinitivo])
  @@map("usuario")
}

model PerfilAcesso {
  id             Int                         @id @default(autoincrement())
  nome           String
  codigo         String                      @unique
  descricao      String?
  ativo          Boolean                     @default(true)
  sistemaPadrao  Boolean                     @default(false)
  perfilLegado   PerfilUsuario?              @unique
  criadoEm       DateTime                    @default(now())
  atualizadoEm   DateTime                    @updatedAt
  usuarios       Usuario[]
  permissoes     PerfilPermissao[]
  auditorias     PerfilPermissaoAuditoria[]

  @@index([ativo, codigo])
  @@map("perfil_acesso")
}

model Permissao {
  id           Int               @id @default(autoincrement())
  codigo       String            @unique
  nome         String
  descricao   String?
  grupo        String
  modulo       String?
  acao         String
  sensivel     Boolean           @default(false)
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt
  perfis       PerfilPermissao[]

  @@index([grupo, modulo, acao])
  @@index([sensivel])
  @@map("permissao")
}

model PerfilPermissao {
  id           Int          @id @default(autoincrement())
  perfilId     Int
  perfil       PerfilAcesso @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  permissaoId  Int
  permissao    Permissao    @relation(fields: [permissaoId], references: [id], onDelete: Cascade)
  permitido    Boolean      @default(true)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  @@unique([perfilId, permissaoId])
  @@index([permissaoId, permitido])
  @@map("perfil_permissao")
}

model PerfilPermissaoAuditoria {
  id                Int          @id @default(autoincrement())
  perfilId          Int
  perfil            PerfilAcesso @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  perfilCodigo      String
  alteradoPorId     Int?
  alteradoPorNome   String?
  permissoesAntes   Json
  permissoesDepois  Json
  resumo            String?
  criadoEm          DateTime     @default(now())

  @@index([perfilId, criadoEm])
  @@index([alteradoPorId, criadoEm])
  @@map("perfil_permissao_auditoria")
}

model UsuarioSessao {
  id           Int       @id @default(autoincrement())
  tokenHash    String    @unique
  usuarioId    Int
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiraEm     DateTime
  ultimoAcesso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([usuarioId])
  @@index([expiraEm])
  @@map("usuario_sessao")
}

model SolicitacaoRedefinicaoSenha {
  id                    Int                               @id @default(autoincrement())
  usuarioId             Int?
  usuario               Usuario?                          @relation("SolicitacaoUsuarioAlvo", fields: [usuarioId], references: [id], onDelete: SetNull)
  nomeUsuarioInformado  String
  nomeCompletoInformado String
  status                StatusSolicitacaoRedefinicaoSenha @default(PENDENTE)
  observacaoInterna     String?
  tratadoPorId          Int?
  tratadoPor            Usuario?                          @relation("SolicitacaoTratadaPor", fields: [tratadoPorId], references: [id], onDelete: SetNull)
  tratadoEm             DateTime?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt

  @@index([status])
  @@index([usuarioId])
  @@map("solicitacao_redefinicao_senha")
}

model LogAssinatura {
  id           Int                   @id @default(autoincrement())
  usuarioId    Int
  usuario      Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  nomeUsuario  String
  nomeCompleto String
  perfil       PerfilUsuario
  tipo         TipoAssinaturaSistema
  modulo       String
  referenciaId String?
  observacao   String?
  assinadoEm   DateTime              @default(now())
  createdAt    DateTime              @default(now())

  @@index([usuarioId])
  @@index([tipo, assinadoEm])
  @@index([modulo, assinadoEm])
  @@map("log_assinatura")
}

model HigienizacaoHortifruti {
  id               Int      @id @default(autoincrement())
  data             DateTime @db.Date
  hortifruti       String
  produtoUtilizado String
  inicioProcesso   String
  terminoProcesso  String
  duracaoMinutos   Int
  responsavel      String
  observacoes      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([data])
  @@index([hortifruti])
  @@index([responsavel])
  @@map("higienizacao_hortifruti")
}

model HigienizacaoHortifrutiFechamento {
  id                 Int                        @id @default(autoincrement())
  mes                Int
  ano                Int
  responsavelTecnico String
  dataAssinatura     DateTime
  status             StatusFechamentoHortifruti @default(ABERTO)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([mes, ano])
  @@map("higienizacao_hortifruti_fechamento")
}

model HigienizacaoHortifrutiOpcao {
  id        Int                   @id @default(autoincrement())
  tipo      TipoOpcaoHigienizacao
  nome      String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([tipo, nome])
  @@index([tipo])
  @@map("higienizacao_hortifruti_opcao")
}

model ControleTemperaturaEquipamento {
  id                               Int                             @id @default(autoincrement())
  data                             DateTime                        @db.Date
  equipamento                      String
  categoriaEquipamento             CategoriaEquipamentoTemperatura
  turno                            TurnoTemperaturaEquipamento
  statusOperacionalEquipamento     StatusOperacionalEquipamento    @default(EM_OPERACAO)
  temperaturaAferida               Float?
  status                           StatusTemperaturaEquipamento
  acaoCorretiva                    String?
  fotoNome                         String?
  fotoMimeType                     String?
  fotoBase64                       String?                         @db.Text
  responsavel                      String
  observacoes                      String?
  observacaoStatusOperacional      String?
  assinaturaNutricionistaUsuarioId Int?
  assinaturaNutricionistaNome      String?
  assinaturaNutricionistaPerfil    PerfilUsuario?
  assinaturaNutricionistaDataHora  DateTime?
  createdAt                        DateTime                        @default(now())
  updatedAt                        DateTime                        @updatedAt

  @@index([data])
  @@index([equipamento])
  @@index([status])
  @@index([statusOperacionalEquipamento])
  @@index([responsavel])
  @@index([assinaturaNutricionistaDataHora])
  @@map("controle_temperatura_equipamentos")
}

model ControleTemperaturaEquipamentoFechamento {
  id                 Int                                    @id @default(autoincrement())
  mes                Int
  ano                Int
  responsavelTecnico String
  dataAssinatura     DateTime
  status             StatusFechamentoTemperaturaEquipamento @default(ABERTO)
  createdAt          DateTime                               @default(now())
  updatedAt          DateTime                               @updatedAt

  @@unique([mes, ano])
  @@map("controle_temperatura_equipamentos_fechamento")
}

model ControleTemperaturaEquipamentoOpcao {
  id                   Int                              @id @default(autoincrement())
  tipo                 TipoOpcaoTemperaturaEquipamento
  nome                 String
  categoriaEquipamento CategoriaEquipamentoTemperatura?
  ativo                Boolean                          @default(true)
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt

  @@unique([tipo, nome])
  @@index([tipo, ativo])
  @@map("controle_temperatura_equipamentos_opcao")
}

model ControleTemperaturaCategoriaParametro {
  id                        Int                                 @id @default(autoincrement())
  categoria                 CategoriaEquipamentoTemperatura     @unique
  nome                      String
  temperaturaIdealMin       Float?
  temperaturaIdealMax       Float?
  temperaturaAlertaMin      Float?
  temperaturaAlertaMax      Float?
  temperaturaCriticaMin     Float?
  temperaturaCriticaMax     Float?
  acaoIdeal                 String                              @default("")
  acaoAlerta                String                              @default("")
  acaoCritica               String                              @default("")
  orientacaoCorretivaPadrao String
  isActive                  Boolean                             @default(true)
  createdAt                 DateTime                            @default(now())
  updatedAt                 DateTime                            @updatedAt
  regras                    ControleTemperaturaCategoriaRegra[]

  @@index([isActive])
  @@map("controle_temperatura_categoria_parametro")
}

model ControleTemperaturaCategoriaRegra {
  id             Int                                   @id @default(autoincrement())
  categoriaId    Int
  categoria      ControleTemperaturaCategoriaParametro @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  temperaturaMin Float?
  temperaturaMax Float?
  status         StatusTemperaturaEquipamento
  acaoCorretiva  String
  ordem          Int
  isActive       Boolean                               @default(true)
  createdAt      DateTime                              @default(now())
  updatedAt      DateTime                              @updatedAt

  @@unique([categoriaId, ordem])
  @@index([categoriaId, isActive, ordem])
  @@map("controle_temperatura_categoria_regra")
}

model ControleQualidadeOleoRegistro {
  id                            Int                 @id @default(autoincrement())
  data                          DateTime            @db.Date
  fitaOleo                      String?
  temperatura                   Float?
  status                        StatusQualidadeOleo
  orientacao                    String
  responsavel                   String
  observacao                    String?
  temperaturaCritica            Boolean             @default(false)
  semUtilizacao                 Boolean             @default(false)
  assinaturaSupervisorUsuarioId Int?
  assinaturaSupervisorNome      String?
  assinaturaSupervisorPerfil    PerfilUsuario?
  assinaturaSupervisorEm        DateTime?
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt

  @@index([data])
  @@index([fitaOleo])
  @@index([status])
  @@index([responsavel])
  @@index([assinaturaSupervisorEm])
  @@map("controle_qualidade_oleo_registro")
}

model ControleQualidadeOleoFechamento {
  id                 Int                           @id @default(autoincrement())
  mes                Int
  ano                Int
  responsavelTecnico String
  dataAssinatura     DateTime
  status             StatusFechamentoQualidadeOleo @default(ABERTO)
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  @@unique([mes, ano])
  @@map("controle_qualidade_oleo_fechamento")
}

model ControleQualidadeOleoOpcaoFita {
  id              Int                 @id @default(autoincrement())
  rotulo          String
  descricao       String
  statusAssociado StatusQualidadeOleo
  ordem           Int                 @default(1)
  ativo           Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([rotulo])
  @@index([ativo, ordem])
  @@map("controle_qualidade_oleo_opcao_fita")
}

model RastreabilidadeRecebimentoCategoria {
  id                Int                                  @id @default(autoincrement())
  nome              String
  temperaturaMaxima Float
  ativo             Boolean                              @default(true)
  createdAt         DateTime                             @default(now())
  updatedAt         DateTime                             @updatedAt
  registros         RastreabilidadeRecebimentoRegistro[]

  @@unique([nome])
  @@index([ativo, nome])
  @@map("rastreabilidade_recebimento_categoria")
}

model RastreabilidadeRecebimentoNota {
  id                  Int                                  @id @default(autoincrement())
  data                DateTime                             @db.Date
  fornecedor          String
  notaFiscal          String
  chaveNfe            String?                              @unique
  cnpjFornecedor      String?
  serieNota           String?
  identificadorFiscal String?                              @unique
  statusNota          StatusNotaRecebimento                @default(PENDENTE)
  responsavelGeral    String?
  origemXml           Boolean                              @default(false)
  createdAt           DateTime                             @default(now())
  updatedAt           DateTime                             @updatedAt
  itens               RastreabilidadeRecebimentoRegistro[]

  @@index([data])
  @@index([fornecedor])
  @@index([notaFiscal])
  @@index([cnpjFornecedor])
  @@index([serieNota])
  @@index([notaFiscal, cnpjFornecedor, serieNota])
  @@index([statusNota])
  @@map("rastreabilidade_recebimento_nota")
}

model RastreabilidadeRecebimentoRegistro {
  id                      Int                                  @id @default(autoincrement())
  notaId                  Int?
  nota                    RastreabilidadeRecebimentoNota?      @relation(fields: [notaId], references: [id], onDelete: Cascade)
  data                    DateTime                             @db.Date
  produto                 String
  codigoProdutoXml        String?
  ncm                     String?
  cfop                    String?
  quantidadeComprada      Float?
  unidadeMedidaCompra     String?
  valorUnitario           Float?
  valorTotalItem          Float?
  quantidadeTributavel    Float?
  unidadeMedidaTributavel String?
  valorUnitarioTributavel Float?
  fornecedor              String
  notaFiscal              String
  lote                    String?
  dataFabricacao          DateTime?                            @db.Date
  dataValidade            DateTime?                            @db.Date
  validadeNaoAplicavel    Boolean                              @default(false)
  sif                     String?
  temperatura             Float?
  temperaturaTipo         TipoTemperaturaRecebimento           @default(NUMERICA)
  temperaturaStatus       ConformidadeRecebimento?
  transporteEntregador    ConformidadeRecebimento?
  aspectoSensorial        ConformidadeRecebimento?
  embalagem               ConformidadeRecebimento?
  acaoCorretiva           String?
  responsavelRecebimento  String?
  observacoes             String?
  statusGeral             StatusRecebimento                    @default(PENDENTE)
  origemXml               Boolean                              @default(false)
  categoriaId             Int?
  categoria               RastreabilidadeRecebimentoCategoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  createdAt               DateTime                             @default(now())
  updatedAt               DateTime                             @updatedAt

  @@index([data])
  @@index([produto])
  @@index([fornecedor])
  @@index([notaFiscal])
  @@index([statusGeral])
  @@index([responsavelRecebimento])
  @@index([categoriaId])
  @@index([notaId])
  @@map("rastreabilidade_recebimento_registro")
}

model RastreabilidadeRecebimentoFechamento {
  id                 Int                                        @id @default(autoincrement())
  mes                Int
  ano                Int
  responsavelTecnico String
  dataAssinatura     DateTime
  status             StatusFechamentoRastreabilidadeRecebimento @default(ABERTO)
  createdAt          DateTime                                   @default(now())
  updatedAt          DateTime                                   @updatedAt

  @@unique([mes, ano])
  @@map("rastreabilidade_recebimento_fechamento")
}

model PlanoLimpezaDiarioRegistro {
  id                               Int                     @id @default(autoincrement())
  data                             DateTime                @db.Date
  turno                            TurnoPlanoLimpeza
  area                             String
  itemId                           Int?
  item                             PlanoLimpezaDiarioItem? @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemDescricao                    String?
  produtoUtilizado                 String?
  setorResponsavel                 String?
  funcionarioResponsavel           String?
  assinaturaResponsavel            String                  @default("")
  assinaturaResponsavelUsuarioId   Int?
  assinaturaResponsavelNomeUsuario String?
  assinaturaResponsavelPerfil      PerfilUsuario?
  assinaturaResponsavelDataHora    DateTime?
  assinaturaSupervisor             String                  @default("")
  assinaturaSupervisorUsuarioId    Int?
  assinaturaSupervisorNomeUsuario  String?
  assinaturaSupervisorPerfil       PerfilUsuario?
  assinaturaSupervisorDataHora     DateTime?
  observacao                       String?
  observacaoResponsavel            String?
  observacaoSupervisor             String?
  status                           StatusPlanoLimpeza      @default(PENDENTE)
  createdAt                        DateTime                @default(now())
  updatedAt                        DateTime                @updatedAt

  @@unique([data, turno, itemId])
  @@index([data])
  @@index([turno])
  @@index([area])
  @@index([status])
  @@index([itemId])
  @@index([assinaturaResponsavel])
  @@index([assinaturaResponsavelDataHora])
  @@index([assinaturaSupervisorDataHora])
  @@map("plano_limpeza_diario_registro")
}

model PlanoLimpezaDiarioArea {
  id                  Int                      @id @default(autoincrement())
  nome                String                   @unique
  detalhamentoLimpeza String?                  @db.Text
  turnoManha          Boolean                  @default(true)
  turnoTarde          Boolean                  @default(true)
  turnoNoite          Boolean                  @default(true)
  ativo               Boolean                  @default(true)
  ordem               Int                      @default(1)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  itens               PlanoLimpezaDiarioItem[]

  @@index([ativo, ordem, nome])
  @@map("plano_limpeza_diario_area")
}

model PlanoLimpezaDiarioItem {
  id                     Int                          @id @default(autoincrement())
  areaId                 Int
  area                   PlanoLimpezaDiarioArea       @relation(fields: [areaId], references: [id], onDelete: Restrict)
  descricao              String
  produtoUtilizado       String?
  setorResponsavel       String?
  funcionarioResponsavel String?
  ordem                  Int                          @default(1)
  ativo                  Boolean                      @default(true)
  excluidoEm             DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  execucoes              PlanoLimpezaDiarioRegistro[]

  @@index([areaId])
  @@index([excluidoEm])
  @@index([areaId, ativo, ordem])
  @@map("plano_limpeza_diario_item")
}

model PlanoLimpezaSemanalItem {
  id               Int                           @id @default(autoincrement())
  area             String
  oQueLimpar       String
  qualProduto      String
  quando           String?
  setorResponsavel String?
  quem             String
  ativo            Boolean                       @default(true)
  excluidoEm       DateTime?
  ordem            Int                           @default(1)
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  execucoes        PlanoLimpezaSemanalExecucao[]

  @@index([area])
  @@index([excluidoEm])
  @@index([ativo, area, ordem])
  @@map("plano_limpeza_semanal_item")
}

model PlanoLimpezaSemanalArea {
  id         Int       @id @default(autoincrement())
  nome       String    @unique
  ativo      Boolean   @default(true)
