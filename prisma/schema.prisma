  nome          String                         @unique
  unidadePadrao String
  observacao    String?                        @db.Text
  ativo         Boolean                        @default(true)
  criadoEm      DateTime                       @default(now())
  atualizadoEm  DateTime                       @updatedAt
  grupos        EtiquetaValidadeProdutoGrupo[]
  regras        EtiquetaValidadeRegra[]
  etiquetas     EtiquetaValidadeEmissao[]

  @@index([ativo, nome])
  @@map("etiqueta_validade_produto")
}

model EtiquetaValidadeProdutoGrupo {
  produtoId Int
  grupoId   Int
  produto   EtiquetaValidadeProduto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  grupo     EtiquetaValidadeGrupo   @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  criadoEm  DateTime                @default(now())

  @@id([produtoId, grupoId])
  @@index([grupoId])
  @@map("etiqueta_validade_produto_grupo")
}

model EtiquetaValidadeMetodo {
  id           Int                       @id @default(autoincrement())
  nome         String                    @unique
  tipo         String?
  icone        String?
  ordem        Int                       @default(0)
  ativo        Boolean                   @default(true)
  criadoEm     DateTime                  @default(now())
  atualizadoEm DateTime                  @updatedAt
  regras       EtiquetaValidadeRegra[]
  etiquetas    EtiquetaValidadeEmissao[]

  @@index([ativo, ordem, nome])
  @@map("etiqueta_validade_metodo")
}

model EtiquetaValidadeRegra {
  id                    Int                       @id @default(autoincrement())
  produtoId             Int?
  produto               EtiquetaValidadeProduto?  @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  grupoId               Int?
  grupo                 EtiquetaValidadeGrupo?    @relation(fields: [grupoId], references: [id], onDelete: SetNull)
  metodoId              Int
  metodo                EtiquetaValidadeMetodo    @relation(fields: [metodoId], references: [id], onDelete: Restrict)
  validadeDias          Int?
  validadeHoras         Int?
  exigeValidadeManual   Boolean                   @default(false)
  temperaturaReferencia String?
  observacao            String?                   @db.Text
  prioridade            Int                       @default(0)
  ativo                 Boolean                   @default(true)
  criadoEm              DateTime                  @default(now())
  atualizadoEm          DateTime                  @updatedAt
  etiquetas             EtiquetaValidadeEmissao[]

  @@index([produtoId, metodoId, ativo])
  @@index([grupoId, metodoId, ativo])
  @@index([metodoId, ativo])
  @@index([ativo, prioridade])
  @@map("etiqueta_validade_regra")
}

model EtiquetaValidadeEmissao {
  id                            Int                         @id @default(autoincrement())
  codigoEtiqueta                String                      @unique
  produtoId                     Int?
  produto                       EtiquetaValidadeProduto?    @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  grupoId                       Int?
  grupo                         EtiquetaValidadeGrupo?      @relation("EtiquetaValidadeEmissaoGrupo", fields: [grupoId], references: [id], onDelete: SetNull)
  subgrupoId                    Int?
  subgrupo                      EtiquetaValidadeGrupo?      @relation("EtiquetaValidadeEmissaoSubgrupo", fields: [subgrupoId], references: [id], onDelete: SetNull)
  metodoId                      Int?
  metodo                        EtiquetaValidadeMetodo?     @relation(fields: [metodoId], references: [id], onDelete: SetNull)
  regraValidadeId               Int?
  regraValidade                 EtiquetaValidadeRegra?      @relation(fields: [regraValidadeId], references: [id], onDelete: SetNull)
  produtoNomeSnapshot           String
  grupoNomeSnapshot             String?
  subgrupoNomeSnapshot          String?
  metodoNomeSnapshot            String
  validadeDiasSnapshot          Int?
  validadeHorasSnapshot         Int?
  temperaturaReferenciaSnapshot String?
  quantidade                    String?
  unidadeSnapshot               String
  dataManipulacao               DateTime                    @db.Date
  horaManipulacao               String
  dataValidade                  DateTime                    @db.Date
  horaValidade                  String
  responsavelUsuarioId          Int
  responsavel                   Usuario                     @relation("EtiquetaValidadeEmissaoResponsavel", fields: [responsavelUsuarioId], references: [id], onDelete: Restrict)
  responsavelNomeSnapshot       String
  responsavelPerfilSnapshot     PerfilUsuario
  marcaFornecedor               String?
  sif                           String?
  lote                          String?
  validadeOriginal              DateTime?                   @db.Date
  observacao                    String?                     @db.Text
  origem                        EtiquetaValidadeOrigemRegra @default(AUTOMATICA)
  criadoEm                      DateTime                    @default(now())

  @@index([produtoId])
  @@index([grupoId])
  @@index([subgrupoId])
  @@index([metodoId])
  @@index([regraValidadeId])
  @@index([responsavelUsuarioId])
  @@index([dataValidade])
  @@index([criadoEm])
  @@index([origem])
  @@map("etiqueta_validade_emissao")
}
